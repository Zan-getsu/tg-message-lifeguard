API_ID=
API_HASH=
SOURCE_GROUP_ID=
DESTINATION_GROUP_ID=
BOT_TOKEN=
USE_BOT_FOR_DOWNLOAD=false

# Number of parallel TCP connections used for uploads (each = separate socket to Telegram DC).
# Recommended: 10. Max: 20. More connections = faster uploads, but too many may trigger FloodWait.
WORKERS=10

# Number of parallel workers for downloads (uses Telethon iter_download).
# Recommended: 8.
DOWNLOAD_WORKERS=8
